# Required in Railway for database-backed authentication.
DATABASE_URL=

# Required for signing session cookies/tokens. Generate a long random value.
JWT_SECRET=

# Public application URL used in magic-link and other transactional emails.
# Prefer the custom domain in production.
PUBLIC_APP_URL=https://app.iheartecho.com
# Backwards-compatible alias used by Vite/client code.
VITE_APP_URL=https://app.iheartecho.com

# Railway also provides RAILWAY_PUBLIC_DOMAIN automatically. The server will
# use it as a fallback if PUBLIC_APP_URL / APP_URL / VITE_APP_URL are absent.
# RAILWAY_PUBLIC_DOMAIN=app.iheartecho.com

# Required for sending magic-link emails through SendGrid.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@iheartecho.com
SENDGRID_FROM_NAME=iHeartEcho

# OAuth/Manus integration values, if this deployment uses Manus auth features.
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Optional integrations used elsewhere in the app.
THINKIFIC_API_KEY=
THINKIFIC_SUBDOMAIN=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
